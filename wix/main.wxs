<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v7 installer definition for SSG Tether Capture.

  BUILD PROCESS (release.yml / packaging-test.yml):
    dotnet restore wix/SSG.wixproj
    dotnet build  wix/SSG.wixproj -c Release

  UPGRADE GUID: must never change across versions — it identifies this product family.
    Changing it breaks the upgrade path and causes side-by-side installs.

  INSTALL SCOPES:
    WixUI_Advanced lets the user choose at install time:
      Per-Machine (default) – installed to %ProgramFiles%\SSG Tether Capture, requires admin elevation.
      Per-User (no admin)   – installed to %LocalAppData%\SSG Tether Capture, no UAC prompt.

  WIZARD SCREENS:
    Welcome → License Agreement → Install Type (per-machine / per-user) →
    Install Directory → Shortcut Options → Ready → Progress → Finish
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="SSG Tether Capture"
    Manufacturer="Conjunction Crew"
    Version="$(var.PackageVersion)"
    Language="1033"
    UpgradeCode="10AA6E67-5472-4441-A59D-80D264B3F068"
    Scope="perMachine">

    <SummaryInformation Description="SSG Tether Capture Installer" />

    <!-- ──────────────────────────────────────────────────────────────────
         Upgrade: auto-remove old version before installing the new one.
         AllowSameVersionUpgrades prevents the installer from aborting when
         re-running the same version (e.g. repair).
    ─────────────────────────────────────────────────────────────────── -->
    <MajorUpgrade
      Schedule="afterInstallInitialize"
      AllowSameVersionUpgrades="yes"
      DowngradeErrorMessage="A newer version of [ProductName] is already installed. Setup will now exit." />

    <!-- ──────────────────────────────────────────────────────────────────
         Media / cabinet
    ─────────────────────────────────────────────────────────────────── -->
    <Media Id="1" Cabinet="ssg.cab" EmbedCab="yes" />

    <!-- ──────────────────────────────────────────────────────────────────
         App icon shown in Add/Remove Programs
    ─────────────────────────────────────────────────────────────────── -->
    <Icon Id="AppIcon.ico" SourceFile="..\assets\logo\icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <!-- ──────────────────────────────────────────────────────────────────
         Per-user / per-machine install scope support.
         WixUI_Advanced displays the scope-selection dialog.
         MSIINSTALLPERUSER=1  → per-user (LocalAppData), no elevation required.
         MSIINSTALLPERUSER unset → per-machine (ProgramFiles), requires admin.
         We default to per-machine but the user can switch in the wizard.
         Marked Secure="yes" so the UI dialog can set it at install time.
    ─────────────────────────────────────────────────────────────────── -->
    <Property Id="ApplicationFolderName" Value="SSG Tether Capture" />
    <Property Id="WixAppFolder"          Value="WixPerMachineFolder" />
    <Property Id="MSIINSTALLPERUSER"     Secure="yes" />

    <!-- Shortcut options: both enabled by default; user can deselect -->
    <Property Id="INSTALL_STARTMENU" Value="1" />
    <Property Id="INSTALL_DESKTOP"   Value="1" />

    <!-- ──────────────────────────────────────────────────────────────────
         Directory layout.
         APPLICATIONFOLDER is set by WixUI_Advanced based on the user's
         scope choice at install time:
           per-machine → ProgramFiles64Folder\SSG Tether Capture
           per-user    → LocalAppDataFolder\Programs\SSG Tether Capture
         WixUI_Advanced resolves the per-user path internally via
         ApplicationFolderName; we only need the per-machine anchor here.
    ─────────────────────────────────────────────────────────────────── -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="APPLICATIONFOLDER" Name="SSG Tether Capture" />
    </StandardDirectory>

    <!-- Start Menu Programs folder -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="SSG Tether Capture" />
    </StandardDirectory>

    <!-- Desktop shortcut directory -->
    <StandardDirectory Id="DesktopFolder" />

    <!-- ──────────────────────────────────────────────────────────────────
         Components — main executable
    ─────────────────────────────────────────────────────────────────── -->
    <ComponentGroup Id="MainFiles" Directory="APPLICATIONFOLDER">
      <Component Id="MainExecutable" Guid="AAE3D0CC-5F9E-4E64-BBB1-F434C5047399">
        <File
          Id="MainExe"
          Name="ssg_tether_capture.exe"
          Source="..\target\release\ssg_tether_capture.exe"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Assets bundle (all files under assets/) installed alongside the exe -->
    <ComponentGroup Id="AssetFiles" Directory="APPLICATIONFOLDER">
      <Files Include="..\assets\**\*.*" />
    </ComponentGroup>

    <!-- ──────────────────────────────────────────────────────────────────
         Start Menu shortcut (conditional on INSTALL_STARTMENU property)
    ─────────────────────────────────────────────────────────────────── -->
    <ComponentGroup Id="StartMenuShortcuts" Directory="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcut" Guid="B1C2D3E4-F567-4890-ABCD-EF1234567890" Condition="INSTALL_STARTMENU">
        <Shortcut
          Id="StartMenuShortcutEntry"
          Name="SSG Tether Capture"
          Description="SSG Tether Capture — orbital debris capture simulation"
          Target="[APPLICATIONFOLDER]ssg_tether_capture.exe"
          WorkingDirectory="APPLICATIONFOLDER"
          Icon="AppIcon.ico" />
        <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\ConjunctionCrew\SSGTetherCapture"
          Name="StartMenuInstalled"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ──────────────────────────────────────────────────────────────────
         Desktop shortcut (conditional on INSTALL_DESKTOP property)
    ─────────────────────────────────────────────────────────────────── -->
    <ComponentGroup Id="DesktopShortcuts" Directory="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="C2D3E4F5-6789-4ABC-DEF0-123456789ABC" Condition="INSTALL_DESKTOP">
        <Shortcut
          Id="DesktopShortcutEntry"
          Name="SSG Tether Capture"
          Description="SSG Tether Capture — orbital debris capture simulation"
          Target="[APPLICATIONFOLDER]ssg_tether_capture.exe"
          WorkingDirectory="APPLICATIONFOLDER"
          Icon="AppIcon.ico" />
        <RegistryValue
          Root="HKCU"
          Key="Software\ConjunctionCrew\SSGTetherCapture"
          Name="DesktopInstalled"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ──────────────────────────────────────────────────────────────────
         Features
    ─────────────────────────────────────────────────────────────────── -->
    <Feature Id="MainFeature" Title="SSG Tether Capture" Level="1">
      <ComponentGroupRef Id="MainFiles" />
      <ComponentGroupRef Id="AssetFiles" />
      <ComponentGroupRef Id="StartMenuShortcuts" />
      <ComponentGroupRef Id="DesktopShortcuts" />
    </Feature>

    <!-- ──────────────────────────────────────────────────────────────────
         Wizard UI — WixUI_Advanced:
           Welcome → License Agreement → Install Type (per-machine/per-user)
           → Directory → Shortcuts → Ready → Progress → Finish
         WixUILicenseRtf points to our LICENSE.rtf.
    ─────────────────────────────────────────────────────────────────── -->
    <ui:WixUI Id="WixUI_Advanced" />

    <WixVariable Id="WixUILicenseRtf"    Value="LICENSE.rtf" />
    <WixVariable Id="WixUIBannerBmp"     Value="..\assets\logo\installer_banner.bmp" Overridable="yes" />
    <WixVariable Id="WixUIDialogBmp"     Value="..\assets\logo\installer_dialog.bmp" Overridable="yes" />

  </Package>

</Wix>
